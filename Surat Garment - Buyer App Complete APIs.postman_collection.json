		{
			"name": "2. Home Page",
			"item": [
				{
					"name": "Get Home Page Data",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/home?gender=all",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"home"
							],
							"query": [
								{
									"key": "gender",
									"value": "all",
									"description": "Optional filter: 'all', 'men', 'women', 'kids'"
								}
							]
						}
					},
					"response": [
						{
							"name": "Success Response",
