		{
			"name": "Favourites",
			"item": [
				{
					"name": "My Favourites List",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/favourites?page=1&limit=20&cursor=",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"favourites"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "20"
								},
								{
									"key": "cursor",
									"value": "",
									"description": "Last favourite _id for infinite scroll"
								}
							]
						},
						"description": "Returns all favourited products for the logged-in user. Products deactivated after favouriting are automatically filtered out."
					},
					"response": []
				},
				{
					"name": "Check Favourite Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/favourites/{{productId}}/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"favourites",
								"{{productId}}",
								"status"
							]
						},
						"description": "Returns { isFavourited: bool, favouriteCount: number }. Call this on product list and detail screens to set the initial heart icon state."
					},
					"response": []
				},
				{
					"name": "Toggle Favourite (Heart Tap)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/favourites/{{productId}}/toggle",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"favourites",
								"{{productId}}",
								"toggle"
							]
						},
						"description": "Single call for the heart icon tap. If product is already favourited it removes it; otherwise it adds it. Returns { isFavourited: bool, favouriteCount: number }. Recommended for mobile."
					},
					"response": []
				},
				{
					"name": "Add to Favourites (Explicit)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/favourites/{{productId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"favourites",
								"{{productId}}"
							]
						},
						"description": "Explicitly adds to favourites. Returns 409 if product is already favourited."
					},
					"response": []
				},
				{
					"name": "Remove from Favourites (Explicit)",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/favourites/{{productId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"favourites",
								"{{productId}}"
							]
						},
						"description": "Explicitly removes from favourites. Returns 404 if product was not in favourites."
					},
					"response": []
				}
			]
		}
	],
