							"body": "{\n    \"success\": true,\n    \"data\": {\n        \"storeId\": \"STORE_12345\",\n        \"sections\": [\n            {\n                \"id\": \"sec1\",\n                \"sectionType\": \"SEARCH_BANNER\",\n                \"data\": []\n            },\n            {\n                \"id\": \"sec2\",\n                \"sectionType\": \"CATEGORY_GRID\",\n                \"data\": {\n                    \"categories\": [\n                        {\n                            \"id\": \"cat1\",\n                            \"name\": \"Men\",\n                            \"image\": \"https://link-to-image.jpg\",\n                            \"subcategories\": [\n                                {\n                                    \"name\": \"Shirts\"\n                                }\n                            ]\n                        }\n                    ]\n                }\n            },\n            {\n                \"id\": \"sec3\",\n                \"sectionType\": \"BEST_OFFERS\",\n                \"data\": {\n                    \"title\": \"Best Offers\",\n                    \"products\": [\n                        {\n                            \"id\": \"prod1\",\n                            \"title\": \"Premium Men Shirts 1\",\n                            \"mrp\": 900,\n                            \"sellingPrice\": 600,\n                            \"discountPercentage\": 33,\n                            \"images\": [\"https://link.jpg\"],\n                            \"category\": { \"id\": \"cat1\", \"name\": \"Men\" },\n                            \"subcategory\": \"Shirts\"\n                        }\n                    ]\n                }\n            }\n        ]\n    }\n}"
